<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- System.Memory: Span<T>/ReadOnlySpan<T>/MemoryExtensions(AsSpan) for net481 -->
    <!-- System.Buffers: ArrayPool<T> — 첨부파일 버퍼 풀링으로 LOH 적재·heap 단편화 완화 -->
    <!-- Microsoft.IO.RecyclableMemoryStream은 LOH 프로파일 결과로 필요 시 추가 -->

    <TargetFramework>net481</TargetFramework>
    <OutputType>Library</OutputType>
    <RootNamespace>TlsMailSender</RootNamespace>
    <AssemblyName>TlsMailSender</AssemblyName>
    <ProjectGuid>{4EB9310A-F7B9-49B5-9BFB-235243010AD5}</ProjectGuid>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <ItemGroup>
    <None Include="AllowedCerts.txt" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Memory" Version="4.6.3" />
    <PackageReference Include="System.Buffers" Version="4.6.1" />
    <PackageReference Include="System.Runtime.CompilerServices.Unsafe" Version="6.1.2" />
  </ItemGroup>

</Project>